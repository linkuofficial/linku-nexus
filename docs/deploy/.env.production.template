# Required environment variables for production deployment
APP_ENV=production
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Use your real public domains, comma-separated
CORS_ORIGINS=https://nodus.linku.tech,https://www.nodus.linku.tech

# Required admin key in staging/production
ADMIN_API_KEY=replace_with_long_random_secret

# Optional hardening for admin routes
ADMIN_ALLOWED_IPS=
ADMIN_TRUST_FORWARDED_FOR=true
ADMIN_TRUSTED_PROXIES=
ADMIN_ENABLE_GENERATION_IN_PRODUCTION=false

# Neo4j connection
NEO4J_URI=bolt://your-neo4j-host:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_neo4j_password

# Alert webhook (Slack/Teams compatible)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_MIN_INTERVAL_SECONDS=300

# Admin guardrails
ADMIN_MAX_TASKS=200
ADMIN_TASK_TTL_SECONDS=86400
ADMIN_TRIGGER_WINDOW_SECONDS=60
ADMIN_TRIGGER_MAX_REQUESTS=8
ADMIN_ALERT_PER_MINUTE=12
ADMIN_ALERT_PER_DAY=200
ADMIN_AUDIT_RETENTION_DAYS=30
ADMIN_AUDIT_MAX_FILE_MB=10
ADMIN_AUDIT_MAX_ROTATED_FILES=7
