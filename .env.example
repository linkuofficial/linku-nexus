# ─── Nodus Environment Configuration ───────────────────────────
# Copy to .env and fill in values

# Server
APP_ENV=development
HOST=0.0.0.0
PORT=8000
DEBUG=false
# ⚠️ CORS_ORIGINS=* is ONLY acceptable for local dev. Set to your actual domain in staging/production.
CORS_ORIGINS=http://localhost:5173
# Production example: CORS_ORIGINS=https://nodus.example.com

# Neo4j (optional — falls back to JSON file if unavailable)
# ⚠️ 生產環境必須覆蓋此值：NEO4J_URI=bolt://<your-host>:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Admin API key (required in staging/production; leave empty only in local dev)
ADMIN_API_KEY=
ADMIN_ALLOWED_IPS=
ADMIN_TRUST_FORWARDED_FOR=false
ADMIN_TRUSTED_PROXIES=
# Production hard guard: keep false unless intentionally running paid generation.
ADMIN_ENABLE_GENERATION_IN_PRODUCTION=false

# Admin guardrails (trigger throttling / task retention / volume alerts)
ADMIN_MAX_TASKS=200
ADMIN_TASK_TTL_SECONDS=86400
ADMIN_TRIGGER_WINDOW_SECONDS=60
ADMIN_TRIGGER_MAX_REQUESTS=8
ADMIN_ALERT_PER_MINUTE=12
ADMIN_ALERT_PER_DAY=200
ADMIN_AUDIT_RETENTION_DAYS=30
ADMIN_AUDIT_MAX_FILE_MB=10
ADMIN_AUDIT_MAX_ROTATED_FILES=7

# Runtime notifications (optional; Slack/Teams compatible webhook recommended)
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
ALERT_MIN_INTERVAL_SECONDS=300

# Claude API (for generation scripts)
ANTHROPIC_API_KEY=
